<script setup>
import { ref, onMounted, computed, reactive } from 'vue'
import axios from 'axios'
import { getMusicList } from '../services/musicService.js'
import { 
  MusicalNoteIcon, 
  PlusIcon, 
  PlayIcon, 
  ArrowRightIcon,
  MagnifyingGlassIcon,
  Bars3Icon,
  Squares2X2Icon,
  FolderIcon,
  ClockIcon,
  ArrowsRightLeftIcon,
  ArrowDownCircleIcon,
  EllipsisHorizontalIcon,
  TrashIcon
} from '@heroicons/vue/24/solid'
import { addToQueue, playTrack, clearQueue, currentTrack } from '../stores/audioStore.js'
import { currentUser } from '../stores/authStore.js'

const activeTab = ref('songs')
const activeContent = ref('all')
const loading = ref(true)
const musicList = ref([])
const albums = ref([])
const playlists = ref([])
const searchQuery = ref('')
const selectedPlaylist = ref(null)
const showCreateModal = ref(false)
const newPlaylistName = ref('')
const activeAddMenuSongId = ref(null)

// Click outside directive implementation
const vClickOutside = {
  mounted(el, binding) {
    el.clickOutsideEvent = (event) => {
      if (!(el === event.target || el.contains(event.target))) {
        binding.value(event)
      }
    }
    document.addEventListener('click', el.clickOutsideEvent)
  },
  unmounted(el) {
    document.removeEventListener('click', el.clickOutsideEvent)
  }
}

onMounted(async () => {
  await fetchMusic()
  await fetchAlbums()
  loadPlaylists()
})

const fetchMusic = async () => {
  loading.value = true
  try {
    musicList.value = await getMusicList()
  } catch (error) {
    console.error('Failed to fetch music:', error)
  } finally {
    loading.value = false
  }
}

const fetchAlbums = async () => {
  try {
    const res = await axios.get('/api/albums')
    albums.value = res.data
  } catch (err) {
    console.error('Albums error:', err)
  }
}

const loadPlaylists = () => {
  const saved = localStorage.getItem('wakmusic_playlists')
  if (saved) playlists.value = JSON.parse(saved)
}

const savePlaylists = () => {
  localStorage.setItem('wakmusic_playlists', JSON.stringify(playlists.value))
}

const filteredList = computed(() => {
  if (!searchQuery.value) return musicList.value
  const lowerQuery = searchQuery.value.toLowerCase()
  return musicList.value.filter(music => music.name.toLowerCase().includes(lowerQuery))
})

const playMusic = (music) => {
  addToQueue(music.url)
}

const toggleAddMenu = (song) => {
  if (activeAddMenuSongId.value === song.id) {
    activeAddMenuSongId.value = null
  } else {
    activeAddMenuSongId.value = song.id
  }
}

const addToPlaylist = (song, playlist) => {
  const plIndex = playlists.value.findIndex(p => p.id === playlist.id)
  if (plIndex !== -1) {
    const existingSongs = playlists.value[plIndex].songs || []
    const songExists = existingSongs.find(s => s.id === song.id)
    
    if (!songExists) {
      playlists.value[plIndex].songs.push({
        id: song.id,
        name: song.title,
        url: song.url,
        addedAt: new Date().toISOString()
      })
      savePlaylists()
    }
  }
  activeAddMenuSongId.value = null
}

const createPlaylist = () => {
  if (!newPlaylistName.value.trim()) return
  const newPlaylist = {
    id: Date.now(),
const playPlaylist = (playlist) => {
  if (!playlist.songs.length) return
  clearQueue()
  playlist.songs.forEach(song => addToQueue(song.url))
  playTrack(0)
}
</script>

<style scoped>
.custom-scrollbar::-webkit-scrollbar {
  width: 12px;
}
.custom-scrollbar::-webkit-scrollbar-track {
  background: transparent;
}
.custom-scrollbar::-webkit-scrollbar-thumb {
  background: rgba(255, 255, 255, 0.1);
  border: 3px solid transparent;
  background-clip: content-box;
  border-radius: 10px;
}
.custom-scrollbar::-webkit-scrollbar-thumb:hover {
  background: rgba(255, 255, 255, 0.2);
  border: 3px solid transparent;
  background-clip: content-box;
}

.custom-scrollbar-hide::-webkit-scrollbar {
  display: none;
}

@keyframes fade-in-up {
  from { opacity: 0; transform: translateY(10px); }
  to { opacity: 1; transform: translateY(0); }
}
.animate-fade-in-up { animation: fade-in-up 0.4s ease-out forwards; }
</style>
