              </tr>
            </thead>
            <tbody class="divide-y divide-transparent">
              <tr 
                v-for="(song, index) in filteredList" 
                :key="song.id"
                class="group hover:bg-white/10 transition-colors rounded-lg overflow-hidden cursor-pointer"
